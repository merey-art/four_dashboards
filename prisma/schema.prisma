generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DashboardKind {
  ACCOUNTING
  LEGAL
  LOGISTICS
  CLIENT_SERVICE
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  BOOLEAN
}

model DashboardCustomColumn {
  id        String          @id @default(cuid())
  dashboard DashboardKind
  key       String
  label     String
  fieldType CustomFieldType
  sortOrder Int             @default(0)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([dashboard, key])
  @@index([dashboard, sortOrder])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ClientServiceOrder {
  id               String   @id @default(cuid())
  clientName       String
  orderNumber      String
  quantity         Int
  expectedDelivery DateTime
  codeIssued       Boolean  @default(false)
  customFields     Json     @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model LogisticsContainer {
  id              String   @id @default(cuid())
  containerNumber String
  borderCrossing  String
  routeNote       String?
  status          String
  customFields    Json     @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LegalContract {
  id               String    @id @default(cuid())
  counterparty     String
  partyType        String
  phase            String
  originalReceived Boolean   @default(false)
  contractDate     DateTime?
  customFields     Json      @default("{}")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model AccountingAct {
  id                String    @id @default(cuid())
  counterpartName   String
  party             String
  actKind           String
  actDate           DateTime?
  originalReceived  Boolean   @default(false)
  customFields      Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}
