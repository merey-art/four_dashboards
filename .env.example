DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?sslmode=require"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Тот же хост и порт, что в адресной строке браузера (иначе вход по credentials не сработает).
NEXTAUTH_URL="http://localhost:3000"
# Доверять Host/proto из запроса (нужно для локальной разработки на произвольном порту при AUTH_TRUST_HOST).
AUTH_TRUST_HOST="true"
